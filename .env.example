# Copy to .env and fill in. The app fails to start if GATEWAY_API_KEY is unset.

# REQUIRED: the single fixed API key clients must present as `Authorization: Bearer <key>`.
GATEWAY_API_KEY=change-me-to-a-long-random-secret

# Model
MODEL_PATH=models/yolo11n.onnx
MODEL_ID=yolo11n

# Detection thresholds
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.45

# Input limits (fail closed before decode)
MAX_IMAGE_BYTES=10000000
MAX_IMAGE_PIXELS=16777216

# ONNX Runtime execution provider: cpu | openvino
ONNX_PROVIDER=cpu

# Server
HOST=0.0.0.0
PORT=8000
